# Solana RPC endpoint your strategy will use.
SOLANA_RPC=https://api.mainnet-beta.solana.com

# Default wallet for the demo strategy in src/strategy.ts.
WATCH_WALLET=So11111111111111111111111111111111111111112

# Temporal server (use Temporal Cloud values in production).
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default

# Express HTTP server port.
PORT=3000

# Default agent id used by `npm run agent`.
AGENT_ID=solana-agent
